// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: gallery
// Fields:
//   - url: string (required)
//   - createdAt: timestamp (required)
//   - order: number (optional)
//
// Collection: videos
// Fields:
//   - url: string (required)
//   - storagePath: string (required)
//   - ratio: string (required, enum: ["9:16", "16:9", "1:1"])
//   - createdAt: timestamp (required)
//
// Collection: services
// Fields:
//   - serviceId: string (required)
//   - url: string (required)
//   - updatedAt: timestamp (required)
//
// Collection: users
// Fields:
//   - email: string
//   - role: string
//
// Collection: appointments
// Fields:
//   - name: string (required)
//   - phone: string (required)
//   - service: string (required)
//   - time: string (required)
//   - createdAt: timestamp (required)
//   - status: string (optional)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "dragonballsam86@gmail.com" ||
        request.auth.token.email == "sam@mryou.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isManager() {
      return isAuthenticated() && (
        request.auth.token.email == "manager@mryou.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager')
      );
    }

    function canManage() {
      return isAdmin() || isManager();
    }

    // Gallery Rules
    match /gallery/{imageId} {
      allow read: if true; // Publicly readable
      allow create, update, delete: if canManage();
    }

    // Video Rules
    match /videos/{videoId} {
      allow read: if true; // Publicly readable
      allow create, update, delete: if canManage();
    }

    // Services Rules
    match /services/{serviceId} {
      allow read: if true; // Publicly readable
      allow create, update, delete: if canManage();
    }

    // User Rules
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || canManage());
      allow create: if isAuthenticated() && request.auth.uid == userId && request.resource.data.role == 'user';
      allow update: if canManage();
    }

    // Appointment Rules
    match /appointments/{appointmentId} {
      allow read: if canManage();
      allow create: if true; // Anyone can book
      allow update, delete: if canManage();
    }
  }
}
